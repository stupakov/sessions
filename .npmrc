# Fail fast with a clear message if the toolchain doesn't match the pinned
# version in package.json "engines" (Node 22 LTS / npm 10). Without this, a
# too-new Node (e.g. 26) falls through to a source build of better-sqlite3 that
# breaks on V8 API changes, and npm 11's allow-scripts gate silently skips the
# native rebuild. See .tool-versions / .nvmrc for the exact pinned version.
engine-strict=true
