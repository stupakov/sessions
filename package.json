{
  "name": "ableton-song-manager",
  "version": "0.2.0",
  "description": "Read-only manager for a folder of Ableton Live projects",
  "author": "Alex Stupakov",
  "license": "MIT",
  "private": true,
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "setup": "npm install --ignore-scripts && node node_modules/electron/install.js && npm run rebuild",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "check": "eslint . && vitest run && electron-vite build",
    "pack:mac": "electron-vite build && electron-builder --mac --dir",
    "dist": "electron-vite build && electron-builder --mac",
    "install:mac": "bash scripts/install-mac.sh"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@eslint/js": "^9.39.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^26.0.0",
    "lucide-react": "^0.474.0",
    "postcss": "^8.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7",
    "vitest": "^3.0.4"
  },
  "build": {
    "appId": "net.stupakov.sessions",
    "productName": "Sessions",
    "files": [
      "out/**/*"
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "build/icon.icns",
      "target": "dmg"
    }
  }
}
